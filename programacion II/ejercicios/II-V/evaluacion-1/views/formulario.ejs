<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Alumno</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .grupo { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.5rem; font-weight: bold; color: #1a3a5c; }
        input { 
            width: 100%; 
            padding: 0.75rem; 
            border: 1px solid #ccc; 
            border-radius: 4px; 
            font-size: 1rem;
            font-family: inherit;
        }
        input:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2); }
        form button { margin-top: 1rem; width: 100%; font-weight: bold; font-size: 1.1rem; }
    </style>
</head>
<body>
    <header>
        <h1>📝 Registro de Alumnos</h1>
        <p>Añadir nuevos estudiantes al sistema</p>
    </header>

    <main>
        <section class="card">
            <h2>Datos del Estudiante</h2>
            <form action="/guardar-alumno" method="POST">
                
                <div class="grupo">
                    <label for="ci">Cédula de Identidad:</label>
                    <input type="number" id="ci" name="ci" required placeholder="Ej: 30123456">
                </div>

                <div class="grupo">
                    <label for="nombre">Nombre Completo:</label>
                    <input type="text" id="nombre" name="nombre" required placeholder="Ej: Juan Pérez">
                </div>

                <button type="submit">Guardar Alumno</button>
                
            </form>
        </section>

        <section class="card">
            <ul>
                <li><a href="/">⬅ Volver al inicio</a></li>
            </ul>
        </section>
    </main>

    <footer>
        <p>Programación II · Trayecto II · UPTT</p>
    </footer>
</body>
</html>
